{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matriya.example/schemas/material-state/v1.1.json",
  "title": "MATRIYA Material Behavior Model (MBM) — State Schema",
  "description": "STABLE v1.1. Formal representation of State + Transition for the Material Behavior Model. Principle: everything in chemistry is a state transition; the model describes BEHAVIOUR (matter+energy+environment+time). v1.1 evolved under the Ontology Validation Suite (a falsification attempt across 5 driver families): v1.0's single `driver` and binary `isHypothesis` did NOT survive — v1.1 adds `drivers[]` (coupled drivers), a 7-value `status`, nullable `toState` (unknown), `impossibleReason`, an auto `knowledgeGap`, per-transition `entropy`, and `invariantExceptions`. Provenance still required for observed knowledge — no invented chemistry. Documentation only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "states", "transitions"],
  "properties": {
    "apiVersion": { "const": "material-state/v1.1" },
    "states": { "type": "array", "items": { "$ref": "#/$defs/state" } },
    "transitions": { "type": "array", "items": { "$ref": "#/$defs/transition" } }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceId": { "type": "integer" },
        "url": { "type": "string" },
        "documentType": { "type": "string", "description": "tds / sds / scientific_paper / tga / dsc / ftir / xrd / sem / patent / illustrative ..." },
        "note": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "material", "state", "provenance", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "material": { "type": "string" },
        "state": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "phase": { "enum": ["solid", "liquid", "gas", "gel", "glass", "crystalline", "amorphous", "network", "unknown"] },
        "microstructure": { "type": ["string", "null"] },
        "composition": { "type": ["object", "array", "null"] },
        "interfaces": { "type": "array", "items": { "type": "string" } },
        "energyState": { "type": ["object", "string", "null"] },
        "environment": { "type": ["object", "string", "null"] },
        "time": { "type": ["string", "null"] },
        "properties": { "type": ["object", "array", "null"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fromState", "drivers", "reversibility", "status", "entropy", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "fromState": { "type": "string" },
        "toState": { "type": ["string", "null"], "description": "Ref to a state id. NULL when status='unknown' (State A -> ???)." },
        "drivers": {
          "description": "v1.1: one OR MORE drivers (coupled/multi-driver). Real failures usually come from combinations.",
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["temperature", "humidity", "pressure", "radiation", "uv", "electric_field", "mechanical_stress", "ph", "chemical_agent", "time"] }
        },
        "status": {
          "description": "v1.1: 7-value epistemic status (replaces binary isHypothesis).",
          "enum": ["observed", "replicated", "mechanism_supported", "predicted", "hypothesized", "unknown", "impossible"]
        },
        "impossibleReason": { "type": ["string", "null"], "description": "Required when status='impossible' — why no mechanism exists." },
        "knowledgeGap": {
          "description": "Auto-generated when status='unknown'. Gap-driven experiment planning.",
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "cost": { "type": ["number", "string", "null"] },
            "impact": { "type": ["number", "string", "null"] },
            "priority": { "type": ["number", "string", "null"] }
          }
        },
        "threshold": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": ["number", "string", "null"] },
            "unit": { "type": ["string", "null"] },
            "operator": { "enum": [">=", "<=", "~", "range", ">", "<"] }
          }
        },
        "mechanism": { "type": ["string", "null"] },
        "rate": { "type": ["string", "null"] },
        "reversibility": { "enum": ["reversible", "irreversible", "partial", "conditional", "unknown"] },
        "energy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": ["number", "null"] },
            "unit": { "type": ["string", "null"] },
            "sign": { "enum": ["endothermic", "exothermic", "absorb", "release", "unknown"] }
          }
        },
        "resultingProperties": { "type": "array", "items": { "type": "string" } },
        "entropy": {
          "description": "v1.1: transition uncertainty 0..1. 0 = observed+replicated; 0.5 = hypothesis; 1 = unknown.",
          "type": "number", "minimum": 0, "maximum": 1
        },
        "invariantExceptions": {
          "description": "v1.1: invariants this transition legitimately violates, each WITH a justification. A violation without an exception is 'inconsistent'.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["invariant", "justification"],
            "properties": {
              "invariant": { "enum": ["conservation_of_mass", "entropy_monotonicity", "causality", "equivalence", "continuity"] },
              "justification": { "type": "string" }
            }
          }
        },
        "evidence": {
          "type": "array",
          "description": "Provenance. REQUIRED (>=1) for observed/replicated/mechanism_supported (enforced by the suite); empty is valid for hypothesized/predicted/unknown/impossible.",
          "items": { "$ref": "#/$defs/provenance" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
