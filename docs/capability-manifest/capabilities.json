{
  "manifestVersion": "capability-manifest/v1",
  "note": "Machine-readable catalogue of EXISTING capabilities in the accessible repos. Seeds the future Capability Registry (router selects by capability, not engine name). Data only — not a runtime layer. kind: runtime (DB/HTTP-backed) | pure (deterministic fn, wire via DI).",
  "productFlow": ["identify_project", "connect_knowledge", "filter_relevant", "suggest_next_action", "update_on_new_knowledge"],
  "capabilities": [
    { "id": "ikl_search", "module": "iklSearchEngine.js", "export": "runSearch(input, ctx)", "kind": "runtime", "does": "semantic search over the Industrial Knowledge Library (provenance-based)", "input": "{query, layer?, filters?}, ctx", "output": "Result (observations/evidence, ranked, provenance)", "productStep": "connect_knowledge" },
    { "id": "rag_search", "module": "ragService.js", "export": "search(query, nResults, filterMetadata) / answer+snippets", "kind": "runtime", "does": "vector retrieval + ranked snippets + grounded answer", "input": "query, nResults, metadata", "output": "ranked results / {answerText, snippets}", "productStep": "filter_relevant" },
    { "id": "ikl_vector_store", "module": "iklVectorStore.js", "export": "indexRecord(layerKey, record)", "kind": "runtime", "does": "index/query pgvector records per IKL layer", "input": "layerKey, record", "output": "vector id / matches", "productStep": "update_on_new_knowledge" },
    { "id": "ikl_api", "module": "iklEndpoints.js", "export": "REST /ikl/*", "kind": "runtime", "does": "overview/sources/search/graph/connections/reindex/bulk", "input": "HTTP (auth)", "output": "JSON", "productStep": "connect_knowledge" },
    { "id": "research_gate", "module": "researchGate.js", "export": "validateAndAdvance(sessionId, stage, userId, opts)", "kind": "runtime", "does": "FSCTM K→C→B→N→L gate, no skip (Kernel v1.6)", "input": "session, stage, opts", "output": "advance/deny + audit", "productStep": "suggest_next_action" },
    { "id": "integrity_monitor", "module": "integrityMonitor.js", "export": "runIntegrityCheck(sessionId)", "kind": "runtime", "does": "detect B-integrity violations; lock gate on breach", "input": "sessionId, metrics", "output": "violation/snapshot", "productStep": "suggest_next_action" },
    { "id": "attribution", "module": "lib/answerAttribution.js", "export": "buildAnswerSourcesFromRetrieval", "kind": "runtime", "does": "bind every answer to its evidence; block unsupported generation", "input": "retrieval+answer", "output": "sources/block", "productStep": "filter_relevant" },
    { "id": "krl_router", "module": "krl-router.mjs", "export": "classifyIntent(query)", "kind": "pure", "does": "route query: Relation/Aggregation/Hybrid/Ambiguous; intent-Guard + LAW", "input": "query", "output": "{intent, aggregationOps, plan}", "productStep": "connect_knowledge" },
    { "id": "krl_executor", "module": "krl-executor.mjs", "export": "route(query, ctx) / executePlan(plan, query, ctx)", "kind": "pure", "does": "run the plan through injected {krl, retrieval}; runtime LAW", "input": "query, ctx adapters", "output": "{intent, steps, answer}", "productStep": "suggest_next_action" },
    { "id": "mbm_invariants", "module": "mbm-invariants.mjs", "export": "checkInvariants(doc) / computeCoverage(doc)", "kind": "pure", "does": "5 physical invariants + coverage gate", "input": "MBM doc", "output": "verdicts / coverage", "productStep": "filter_relevant" },
    { "id": "mbm_reliability", "module": "mbm-reliability.mjs", "export": "modelReliabilityIndex(doc, ids)", "kind": "pure", "does": "MRI, confidence, weakest-link, evidence sensitivity, explainability", "input": "doc, path ids", "output": "{mri, weakest, steps}", "productStep": "suggest_next_action" },
    { "id": "mbm_alt_paths", "module": "mbm-alt-paths.mjs", "export": "generatePaths(doc, from, to)", "kind": "pure", "does": "all valid mechanisms, ranked", "input": "doc, endpoints", "output": "ranked paths", "productStep": "connect_knowledge" },
    { "id": "mbm_uncertainty", "module": "mbm-uncertainty.mjs", "export": "attributeUncertainty(doc, ids)", "kind": "pure", "does": "why uncertain (modelGap/evidence/coverage/weakLink) + lever", "input": "doc, ids", "output": "components + recommendation", "productStep": "suggest_next_action" },
    { "id": "mbm_info_gain", "module": "mbm-info-gain.mjs", "export": "informationGain(doc, ids)", "kind": "pure", "does": "value each experiment (ΔMRI, per-component, cost/time)", "input": "doc, ids", "output": "ranked candidates", "productStep": "suggest_next_action" },
    { "id": "mbm_planner", "module": "mbm-experiment-planner.mjs", "export": "planExperiments(doc, ids, budget)", "kind": "pure", "does": "best experiment portfolio under budget", "input": "doc, ids, budget", "output": "portfolio + remaining gaps", "productStep": "suggest_next_action" },
    { "id": "mbm_calibration", "module": "mbm-calibration.mjs", "export": "calibrate(records)", "kind": "pure", "does": "predicted vs observed; bias by type/component", "input": "records", "output": "calibration report", "productStep": "update_on_new_knowledge" },
    { "id": "mbm_learning", "module": "mbm-learning.mjs", "export": "learnCorrections(report)", "kind": "pure", "does": "correction factors from bias", "input": "calibration report", "output": "correction model", "productStep": "update_on_new_knowledge" },
    { "id": "mbm_tension", "module": "mbm-tension-map.mjs", "export": "tensionMap(doc)", "kind": "pure", "does": "model-wide stable/tension/contradiction/gap", "input": "doc", "output": "map + hotspots", "productStep": "filter_relevant" },
    { "id": "mbm_epistemic", "module": "mbm-epistemic.mjs", "export": "epistemicState(doc, ids)", "kind": "pure", "does": "Hypothesized/Corroborated/Confirmed/Refuted/Undecidable", "input": "doc, ids", "output": "state", "productStep": "filter_relevant" },
    { "id": "mbm_readiness", "module": "mbm-readiness.mjs", "export": "researchReadiness(doc, opts)", "kind": "pure", "does": "is the model ready for real data (RRI)", "input": "doc, paths, calibration", "output": "RRI + weakest dim", "productStep": "suggest_next_action" },
    { "id": "mbm_contradiction", "module": "mbm-contradiction-memory.mjs", "export": "contradictionMemory(events)", "kind": "pure", "does": "keep refutations as knowledge; unstable regions", "input": "events", "output": "ledger", "productStep": "update_on_new_knowledge" },
    { "id": "mbm_evidence_aging", "module": "mbm-evidence-aging.mjs", "export": "ageEvidence(ev, now)", "kind": "pure", "does": "provenance-weighted trust (freshness/replication/last-validation)", "input": "evidence, year", "output": "adjusted tier", "productStep": "filter_relevant" },
    { "id": "mbm_discovery", "module": "mbm-discovery.mjs", "export": "discoveryOpportunities(doc)", "kind": "pure", "does": "where new knowledge is most likely", "input": "doc, industrialValue", "output": "ranked opportunities", "productStep": "suggest_next_action" },
    { "id": "failure_pilot", "module": "failure-mbm-pilot.mjs", "export": "runPilot(mbm, corpus)", "kind": "pure", "does": "competing mechanisms / better experiments / ΔK from failures", "input": "mbm, corpus", "output": "yields + verdict", "productStep": "suggest_next_action" },
    { "id": "failure_patterns", "module": "failure-pattern-engine.mjs", "export": "failurePatterns(cases) / negativeKnowledge(cases)", "kind": "pure", "does": "recurring failure motifs + anti-condition boundaries", "input": "cases", "output": "motifs / boundaries", "productStep": "filter_relevant" },
    { "id": "knowledge_phase", "module": "knowledge-phase.mjs", "export": "phaseOfEdge / legalTransition / placeOnDiagram", "kind": "pure", "does": "knowledge as phases + no-jump law", "input": "edges/states", "output": "phase placement", "productStep": "filter_relevant" },
    { "id": "knowledge_energy", "module": "knowledge-energy.mjs", "export": "knowledgeEnergy / compareProjects", "kind": "pure", "does": "effort per ΔK; compare projects on efficiency", "input": "project effort/ΔK", "output": "energy + ranking", "productStep": "suggest_next_action" },
    { "id": "knowledge_transfer", "module": "knowledge-transfer.mjs", "export": "signatureOf / matchSignatures", "kind": "pure", "does": "structural-signature transfer candidates (never conclusions)", "input": "domain event sequences", "output": "similarity + candidate", "productStep": "connect_knowledge" },
    { "id": "ingestion_gates", "module": "ingestion-design-check.mjs", "export": "evaluateIngestionRequest(req)", "kind": "pure", "does": "G1–G6: human/provenance/evidence/anchors/mapping/dual-signoff", "input": "ingestion request", "output": "{promotable, gates}", "productStep": "update_on_new_knowledge" },
    { "id": "gated_flight", "module": "p0-1-gated-flight.mjs", "export": "gatedFlight(...) / passStop(...)", "kind": "pure", "does": "run reasoning only if gates clear; PASS/STOP", "input": "mbm, corpus, dataset, request", "output": "verdict + flight", "productStep": "suggest_next_action" },
    { "id": "first_flight", "module": "first-flight.mjs", "export": "runFirstFlight(...) / driftMonitor(...)", "kind": "pure", "does": "classify Observation/Context/Surprise/Artifact; co-pilot; report", "input": "mbm, corpus, dataset", "output": "post-flight report", "productStep": "update_on_new_knowledge" },
    { "id": "cockpit_export", "module": "export-cockpit-snapshot.mjs", "export": "buildSnapshot()", "kind": "pure", "does": "project engines into a decision-oriented snapshot + static site", "input": "engines", "output": "snapshot + cockpit UI", "productStep": "suggest_next_action" }
  ]
}
